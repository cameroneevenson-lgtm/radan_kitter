      </Attr>
      <Attr num="102" name="Modified" desc="Time file was last modified." type="t" ord="4"
          value="2026-03-02T12:26:57-05:00">
        <Valid perm="r"/>
      </Attr>
      <Attr num="103" name="File size" desc="File size in bytes." type="i" ord="5" value="29644">
        <Valid perm="r"/>
      </Attr>
      <Attr num="105" name="Associated files" desc="Associated files." type="s" ord="6">
        <Valid perm="h"/>
      </Attr>
      <Attr num="107" name="Extension" desc="File name extension." type="s" ord="2" value="sym">
        <Valid perm="r"/>
      </Attr>
      <Attr num="110" name="File name" desc="File name without its extension." type="s" ord="1"
