    <Group class="custom" name="Description" desc="Use these attributes to give a description of the file." ord="2">
      <Attr num="108" name="Title" desc="The title of this file." type="s" ord="1">
        <Valid perm="e" max="80"/>
      </Attr>
      <Attr num="109" name="Comments" desc="Comments about this file." type="s" ord="2">
        <Valid perm="e"/>
      </Attr>
    </Group>
    <Group class="custom" name="Manufacturing" desc="These attributes are the manufacturing properties of the file."
        ord="6">
      <Attr num="119" name="Material" desc="Material." type="s" ord="1" value="-">
        <Valid perm="e" max="100"/>
      </Attr>
      <Attr num="120" name="Thickness" desc="Thickness." type="r" ord="2" value="0.1">
        <Valid perm="e" min="0" max="99999"/>
      </Attr>
      <Attr num="121" name="Thickness units" desc="Thickness units." type="s" ord="4" value="mm">
        <Valid perm="e" expr="mm|in|swg" max="80"/>
      </Attr>
      <Attr num="122" name="Orientation"
          desc="Allowed nest orientations (1=0°, 2=90°, 3=0/90°, 5=0/180°, 6=90/270°, 7=0/90/180/270°, 8=any)." type="i"
          ord="6" value="8">
        <Valid perm="e" min="1" max="8"/>
      </Attr>
      <Attr num="123" name="Cycle time" desc="Cycle time in minutes." type="r" ord="27">
        <Valid perm="e" min="0"/>
      </Attr>
      <Attr num="127" name="Machine" desc="Machine name." type="s" ord="21">
        <Valid perm="e" max="80"/>
      </Attr>
      <Attr num="132" name="Mirror" desc="Whether the part can be mirrored in nesting." type="s" ord="8">
        <Valid perm="e" expr="yes|no" max="80"/>
      </Attr>
      <Attr num="139" name="STL id" desc="Standard Tool Loading file id." type="i" ord="22">
        <Valid perm="e" min="0"/>
      </Attr>
      <Attr num="145" name="Common cutting" desc="Whether the part is suitable for common line cutting in nesting."
          type="s" ord="9">
        <Valid perm="e" expr="none|unrestricted|same part" max="80"/>
      </Attr>
      <Attr num="146" name="Strategy" desc="Autotooling strategy." type="s" ord="23" value="">
        <Valid perm="e" max="60"/>
        <MC machine="psys_Mazak_OPCF_510_3.0kw_TT" value=""/>
      </Attr>
      <Attr num="158" name="Orientation mode"
          desc="Orientation mode of the part (0=Free, 1=Single or Opposite, 2=Single)." type="i" ord="7">
        <Valid perm="e" min="0" max="2"/>
      </Attr>
      <Attr num="160" name="Picking cluster"
          desc="Whether to nest the part in clusters that are suitable for a part picker." type="s" ord="11">
        <Valid perm="e" expr="yes|no" max="80"/>
      </Attr>
      <Attr num="164" name="Weight"
          desc="The weight of the part in lb or kg, depending on the geometry units attribute value." type="r" ord="5"
          value="0">
        <Valid perm="e" min="0"/>
      </Attr>
      <Attr num="181" name="Maximum CC group" desc="The maximum number of parts in a common cut group." type="i"
          ord="10">
        <Valid perm="e" min="2" max="999999"/>
      </Attr>
      <Attr num="186" name="Workflow status" desc="The workflow status of this file." type="s" ord="29" value="1 - OK">
        <Valid perm="e" max="80"/>
        <MC machine="psys_Mazak_OPCF_510_3.0kw_TT" value="1 - OK"/>
      </Attr>
      <Attr num="196" name="Kit of parts" desc="Symbol is a kit of parts (yes=(Non-rigid) kit, no=Rigid nest of parts)."
          type="s" ord="12" value="yes">
        <Valid perm="e" expr="yes|no" max="80"/>
      </Attr>
    </Group>
    <Group class="custom" name="Geometry" desc="These attributes are the geometry properties of the part." ord="5">
      <Attr num="162" name="Area" desc="The area of the part." type="r" ord="6" value="314.1592654">
